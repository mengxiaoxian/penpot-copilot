# =====================================================
# Penpot Copilot - Environment Configuration Example
# =====================================================
# Copy this file to .env and fill in your actual values
# WARNING: Never commit .env file to version control!
# =====================================================

# -----------------------------------------------------
# LLM API Configuration
# -----------------------------------------------------
# Your LLM API Base URL (OpenAI compatible)
# Examples:
#   - OpenAI: https://api.openai.com/v1
#   - DeepSeek: https://api.deepseek.com
#   - Qwen: https://dashscope.aliyuncs.com/compatible-mode/v1
#   - Zhipu: https://open.bigmodel.cn/api/paas/v1
#   - MiniMax: https://api.minimaxi.com/v1
#   - Local Ollama: http://localhost:11434/v1
LLM_API_BASE_URL=YOUR_API_BASE_URL

# Your LLM API Key (keep it secret!)
LLM_API_KEY=YOUR_API_KEY

# Model name to use
# Examples: gpt-4o, deepseek-chat, qwen-turbo, glm-4, etc.
LLM_MODEL_NAME=YOUR_MODEL_NAME

# -----------------------------------------------------
# Penpot Configuration
# -----------------------------------------------------
# Penpot Access Token (if required)
PENPOT_ACCESS_TOKEN=YOUR_TOKEN

# -----------------------------------------------------
# MCP Server Configuration
# -----------------------------------------------------
# WebSocket port for Penpot plugin connection
MCP_WS_PORT=8080

# Development server port
DEV_SERVER_PORT=4400
